#!/usr/bin/env python3
# -*- coding: utf-8 -*-

# This is socket listening version based on asyncio.
# Requires login command to be sent with first request.

import asyncio
import json
import os
import sys

from heppy import Net
from heppy.EPP import REPP
from heppy.Client import Client
from heppy.Config import Config

SIZE = 4096


def check_connection(address):
    if Client.try_connect(address):
        print('{0} already in use'.format(address))
        exit(1)


def build_answer(epp, cmd):
    cmd = cmd.strip()
    if cmd == 'greeting':
        return epp.greeting, 0
    if cmd == 'info':
        return json.dumps(epp.config, indent=4), 0
    if cmd.startswith('wait'):
        try:
            sec = float(cmd[4:])
        except ValueError:
            sec = 1
        return 'waited {0} seconds'.format(sec), sec
    if cmd.startswith('<'):
        return epp.request(cmd), 0
    return 'Error: wrong command: ' + cmd, 0


async def read_query(reader):
    header = await reader.readexactly(4)
    length = Net.int_from_net(header) - 4
    data = b''
    while len(data) < length:
        chunk = await reader.read(min(SIZE, length - len(data)))
        if not chunk:
            break
        data += chunk
    return data.decode('utf-8')


async def write_answer(writer, answer):
    payload = answer.encode('utf-8')
    writer.write(Net.int_to_net(len(payload) + 4))
    writer.write(payload)
    await writer.drain()


def make_handler(epp, state):
    # Only one client is served at a time, matching the original
    # asyncore-based single-handler behaviour.
    async def handle(reader, writer):
        if state['busy']:
            writer.close()
            return
        state['busy'] = True
        try:
            query = await read_query(reader)
            answer, delay = build_answer(epp, query)
            if delay:
                await asyncio.sleep(delay)
            await write_answer(writer, answer)
        except (asyncio.IncompleteReadError, ConnectionError):
            pass
        finally:
            writer.close()
            state['busy'] = False
    return handle


async def main(config):
    address = config['local']['address']
    check_connection(address)

    epp_config = config['epp']
    epp_config['dir'] = config.get_dir()
    epp = REPP(epp_config)
    state = {'busy': False}

    if os.path.exists(address):
        os.unlink(address)
    server = await asyncio.start_unix_server(make_handler(epp, state), path=address, backlog=5)

    async with server:
        await server.serve_forever()


if __name__ == '__main__':
    if len(sys.argv) < 2:
        print('usage: eppyd config.json')
        exit(1)

    asyncio.run(main(Config(sys.argv[1])))
